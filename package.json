{
  "name": "nova-agent",
  "version": "0.1.0",
  "description": "Mini Coding Workbench — 极简桌面编程工作台",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:memory-integration": "node scripts/run-memory-integration-test.mjs",
    "validate:skills": "node scripts/validate-skill-frontmatter.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:node": "node scripts/rebuild-better-sqlite3-node.mjs",
    "spike:memory-electron": "electron scripts/spike/memory-electron.mjs",
    "pack:spike": "electron-builder --config electron-builder.spike.yml --win portable",
    "pack:spike:verify": "node scripts/spike/run-pack-spike-exe.mjs"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "better-sqlite3": "^11.9.1",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "iconv-lite": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "yauzl": "^3.4.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-test-renderer": "^18.3.1",
    "@types/yauzl": "^3.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.15",
    "react-test-renderer": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}

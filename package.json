{
  "name": "nova-agent",
  "version": "0.1.1",
  "description": "长会话与多 Agent 编排的本地桌面 Agent — 缓存感知上下文、Compose 工作流、会话树与记忆检索",
  "author": "许皓辰",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run sync:icon && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "node scripts/run-perf-gate.mjs",
    "test:memory-integration": "node scripts/run-memory-integration-test.mjs",
    "validate:skills": "node scripts/validate-skill-frontmatter.mjs",
    "sync:icon": "node scripts/sync-build-icon.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:node": "node scripts/rebuild-better-sqlite3-node.mjs",
    "spike:memory-electron": "electron scripts/spike/memory-electron.mjs",
    "pack": "npm run sync:icon && electron-builder --config electron-builder.yml --win nsis",
    "pack:spike": "electron-builder --config electron-builder.spike.yml --win portable",
    "pack:spike:verify": "node scripts/spike/run-pack-spike-exe.mjs",
    "dist": "npm run build && npm run pack && node scripts/verify-pack-icons.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "@vscode/ripgrep": "^1.18.0",
    "better-sqlite3": "^11.9.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "iconv-lite": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "yauzl": "^3.4.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-test-renderer": "^18.3.1",
    "@types/yauzl": "^3.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.15",
    "react-test-renderer": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
